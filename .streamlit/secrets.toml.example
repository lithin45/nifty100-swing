# Copy to `.streamlit/secrets.toml` for local use (git-ignored), and paste the
# same keys into Streamlit Community Cloud -> your app -> Settings -> Secrets.
# For the GitHub Actions EOD job, set these as repository Secrets instead.

# --- Dashboard login ---
app_password = "change-me-to-a-strong-password"

# --- Telegram (required for alerts) ---
TELEGRAM_BOT_TOKEN = "123456789:ABCdefGhIJKlmNoPQRstuVWxyz"
TELEGRAM_CHAT_ID   = "987654321"

# --- Optional: only if you switch data.primary_price_source to upstox/dhan ---
# UPSTOX_API_KEY      = ""
# UPSTOX_API_SECRET   = ""
# UPSTOX_ACCESS_TOKEN = ""   # expires daily at 03:30 IST — see README
# DHAN_CLIENT_ID      = ""
# DHAN_ACCESS_TOKEN   = ""

# --- Claude API (optional: only if sentiment.provider = "claude") ---
# Get a key at https://console.anthropic.com . Used by the EOD job for news
# sentiment (Haiku). If absent, sentiment auto-falls back to FinBERT/lexicon.
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"

# --- Optional: ticker-tagged news providers ---
# MARKETAUX_KEY = ""
# EODHD_KEY     = ""
